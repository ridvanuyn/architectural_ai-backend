# ===========================================
# Architectural AI Backend - Environment Template
# ===========================================
# 
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp env.sample .env
#
# Local geliştirme için:
#   cp env.sample .env.local
#
# Production için:
#   cp env.sample .env.production
# ===========================================

# Server Configuration
# --------------------
NODE_ENV=development                    # development | production
PORT=3001                               # API port numarası

# MongoDB Configuration
# ---------------------
# Local MongoDB için:
MONGODB_URI=mongodb://localhost:27017/architectural_ai_dev

# MongoDB Atlas için (production):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/architectural_ai?retryWrites=true&w=majority

# JWT Configuration
# -----------------
# ÖNEMLİ: Production'da mutlaka güçlü, rastgele string'ler kullanın!
# Örnek oluşturma: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-64-chars-long-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-64-chars-long-change-in-production

# CORS Configuration
# ------------------
# Development için:
CORS_ORIGIN=*

# Production için (virgülle ayırarak birden fazla domain ekleyebilirsiniz):
# CORS_ORIGIN=https://your-app.com,https://admin.your-app.com

# ===========================================
# AWS S3 Configuration (Image Storage)
# ===========================================
# S3 bucket kullanmak için AWS credentials'ı doldurun.
# IAM kullanıcısının S3 bucket'a PutObject, GetObject, DeleteObject izinleri olmalı.
#
# Bucket Policy örneği:
# {
#   "Version": "2012-10-17",
#   "Statement": [
#     {
#       "Effect": "Allow",
#       "Action": ["s3:PutObject", "s3:GetObject", "s3:DeleteObject"],
#       "Resource": "arn:aws:s3:::your-bucket-name/*"
#     }
#   ]
# }

AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=eu-central-1
# Mevcut kurulum tek bucket kullanıyor — hem user design hem thumbnails
# buraya yazılıyor. İleride ayırmak istenirse images bucket ayrı olarak
# AWS_S3_BUCKET'a, thumbnails AWS_S3_BUCKET_THUMBNAILS'e yazılabilir.
AWS_S3_BUCKET=architectural-ai-thumbnails
AWS_S3_BUCKET_THUMBNAILS=architectural-ai-thumbnails

# ===========================================
# CloudFront CDN Configuration
# ===========================================
# Listelerde thumbnail'lar CloudFront üzerinden sunulur; detay ve download
# hâlâ S3'e gider. CDN_ENABLED=false → URL helper doğrudan S3 URL'i döner
# (feature flag ile sıfır-risk rollback).
#
# Distribution behaviors (hepsi architectural-ai-thumbnails origin'ine):
#   /thumbnails/*              (liste thumbnail'ları)
#   /generated/*, /originals/* (user design'ları, full-res)

CDN_ENABLED=true
CDN_BASE_URL=https://d31qbpz1e19hhx.cloudfront.net
SIGNED_URL_TTL_SECONDS=120

# ===========================================
# Replicate AI Configuration
# ===========================================
# Replicate API token'ı https://replicate.com/account/api-tokens adresinden alabilirsiniz.
# Interior design model: adirik/interior-design
# 
# Pricing: https://replicate.com/pricing
# - Her görsel dönüşümü yaklaşık $0.01-0.05 arası maliyetlidir

REPLICATE_API_TOKEN=r8_your_replicate_api_token_here

# ===========================================
# AI Model Settings (Optional)
# ===========================================
# Varsayılan değerler çoğu durum için uygundur

# AI_INFERENCE_STEPS=30                 # Daha yüksek = daha kaliteli ama yavaş (20-50)
# AI_GUIDANCE_SCALE=7.5                 # Prompt'a ne kadar bağlı kalınacak (5-15)
# AI_MODEL=INTERIOR_DESIGN              # INTERIOR_DESIGN | STABLE_DIFFUSION

# AI concurrency limit — fal.ai'ye aynı anda max N paralel çağrı.
# 9. istek Mongo'ya yazılır (PROCESSING) ama semafor boşalana kadar bekler.
AI_CONCURRENCY=8

# ===========================================
# In-App Purchase Verification
# ===========================================

# Apple In-App Purchase
# ---------------------
# App Store Connect'ten alınır
APPLE_SHARED_SECRET=your-apple-shared-secret

# Google Play In-App Purchase
# ---------------------------
# Google Cloud Console'dan indirilen service account JSON dosyasının yolu
GOOGLE_SERVICE_ACCOUNT_KEY=./google-service-account.json

# ===========================================
# Webhook Configuration (Optional)
# ===========================================
# Replicate'ten async sonuç almak için webhook URL'i
# REPLICATE_WEBHOOK_URL=https://your-api.com/api/webhooks/replicate

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=debug                         # debug | info | warn | error
