{
  "name": "architectural-ai-backend",
  "version": "1.0.0",
  "description": "Backend API for Architectural AI - Interior Design Transformation App",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "lint": "eslint src/",
    "migrate": "node src/migrations/run.js",
    "migrate:seed": "node src/migrations/seed.js",
    "migrate:rollback": "node src/migrations/rollback.js",
    "pm2": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop architectural-ai-api",
    "pm2:restart": "pm2 restart architectural-ai-api",
    "pm2:logs": "pm2 logs architectural-ai-api",
    "es:sync": "node scripts/sync-elasticsearch.js"
  },
  "keywords": [
    "architectural-ai",
    "interior-design",
    "ai-transformation",
    "room-design",
    "style-transfer",
    "replicate",
    "s3"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.574.0",
    "@aws-sdk/s3-request-presigner": "^3.574.0",
    "@elastic/elasticsearch": "^9.3.4",
    "@fal-ai/client": "^1.9.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "replicate": "^0.32.0",
    "sharp": "^0.33.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
